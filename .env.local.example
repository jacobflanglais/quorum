# ─────────────────────────────────────────────────────────────
# Quorum — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Production values live in Vercel → Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Frontier model APIs (direct, no OpenRouter) ──────────────
# Anthropic:  https://console.anthropic.com/settings/keys
# OpenAI:     https://platform.openai.com/api-keys
# Google AI:  https://aistudio.google.com/apikey
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Single-user gate ─────────────────────────────────────────
# Only this email is allowed to sign in. Set to your address.
QUORUM_OWNER_EMAIL=

# ── Cost guards (defaults shown) ─────────────────────────────
# Per-query estimated-cost ceiling. Queries above this are rejected.
QUORUM_MAX_COST_PER_QUERY_USD=0.30
# Soft monthly budget. App warns when crossed.
QUORUM_MONTHLY_BUDGET_USD=100
