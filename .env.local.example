# ─────────────────────────────────────────────────────────────
# Quorum — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Production values live in Vercel → Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# Project URL:        Supabase → Settings → General (or `https://<ref>.supabase.co`)
# Publishable key:    Supabase → Settings → API Keys → "Publishable key" (sb_publishable_...)
# Secret key:         Supabase → Settings → API Keys → "Secret key" (sb_secret_..., click eye to reveal)
#
# Note: Supabase migrated from JWT-based anon/service_role keys to opaque
# publishable/secret keys. Use the new ones; legacy keys still work but new
# projects should standardize on the new format.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ── Frontier model APIs (direct, no OpenRouter) ──────────────
# Anthropic:  https://console.anthropic.com/settings/keys
# OpenAI:     https://platform.openai.com/api-keys
# Google AI:  https://aistudio.google.com/apikey
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Single-user gate ─────────────────────────────────────────
# Only this email is allowed to sign in. Set to your address.
QUORUM_OWNER_EMAIL=

# ── Cost guards (defaults shown) ─────────────────────────────
# Per-query estimated-cost ceiling. Queries above this are rejected.
QUORUM_MAX_COST_PER_QUERY_USD=0.30
# Soft monthly budget. App warns when crossed.
QUORUM_MONTHLY_BUDGET_USD=100

# ── Synthesizer override (optional) ──────────────────────────
# By default the synthesizer is claude-sonnet-4-6 — chosen to live
# OUTSIDE the voice pool (which uses claude-opus-4-7) so no model
# is judging its own answer. Override only if you have a reason.
# QUORUM_SYNTHESIZER_MODEL=claude-sonnet-4-6

# ── Vercel Cron auth ─────────────────────────────────────────
# Generate a long random string (e.g. `openssl rand -hex 32`).
# Vercel sends this as `Authorization: Bearer <secret>` on every
# cron invocation; the /api/cron/scheduled-tasks endpoint rejects
# anything else. The GitHub Actions workflow also uses this value.
CRON_SECRET=

# ── Resend (email digests for scheduled tasks) ───────────────
# API key:   https://resend.com/api-keys
# From addr: "Quorum <onboarding@resend.dev>" works for testing
#            (free tier sends ONLY to your signup email until you
#            verify a custom domain — fine for single-user)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Quorum <onboarding@resend.dev>
